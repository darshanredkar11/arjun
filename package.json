{
  "name": "arjun",
  "displayName": "Arjun - Smart Context for Kiro",
  "description": "Reduce token consumption with intelligent context selection and compression",
  "version": "0.1.0",
  "engines": {
    "vscode": "^1.80.0"
  },
  "categories": [
    "AI",
    "Utilities"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "arjun.analyzeRepo",
        "title": "Arjun: Analyze Repository"
      },
      {
        "command": "arjun.showContext",
        "title": "Arjun: Build Optimized Context"
      },
      {
        "command": "arjun.compressFile",
        "title": "Arjun: Compress Current File"
      },
      {
        "command": "arjun.compressLogs",
        "title": "Arjun: Compress Logs"
      },
      {
        "command": "arjun.askKiro",
        "title": "Arjun: Ask Kiro (with optimized context)"
      },
      {
        "command": "arjun.askClaude",
        "title": "Arjun: Ask Claude (with optimized context)"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "arjun-explorer",
          "title": "Arjun",
          "icon": "$(zap)"
        }
      ]
    },
    "views": {
      "arjun-explorer": [
        {
          "id": "arjun.stats",
          "name": "Context Stats",
          "type": "webview"
        },
        {
          "id": "arjun.files",
          "name": "Relevant Files",
          "type": "tree"
        }
      ]
    },
    "configuration": {
      "title": "Arjun",
      "properties": {
        "arjun.kiro.apiKey": {
          "type": "string",
          "description": "Kiro API Key (from https://kiro.sh)",
          "scope": "window"
        },
        "arjun.kiro.endpoint": {
          "type": "string",
          "description": "Kiro API Endpoint",
          "default": "https://kiro.sh/api",
          "scope": "window"
        },
        "arjun.claude.apiKey": {
          "type": "string",
          "description": "Claude API Key (from https://console.anthropic.com)",
          "scope": "window"
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run esbuild -- --minify",
    "esbuild": "esbuild ./src/extension.ts --bundle --outfile=dist/extension.js --external:vscode --platform=node --target=node16",
    "watch": "npm run esbuild -- --watch",
    "dev": "npm run esbuild && code --extensionDevelopmentPath=$PWD",
    "test": "jest"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^18.0.0",
    "@types/vscode": "^1.80.0",
    "esbuild": "^0.21.0",
    "typescript": "^5.0.0"
  },
  "dependencies": {
    "better-sqlite3": "^12.11.1",
    "js-tokens": "^9.0.0",
    "web-tree-sitter": "^0.26.9"
  }
}
